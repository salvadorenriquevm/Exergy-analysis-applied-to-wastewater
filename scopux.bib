	correspondence_address = {M. Egiza; Department of Mechanical Engineering, Kafrelsheikh University, Kafrelsheikh, 33516, Egypt; email: Mohamed_Egiza@eng.kfs.edu.eg; A.H. Elsheikh; Production Engineering and Mechanical Design Department, Tanta University, Tanta, 31527, Egypt; email: ammar_elsheikh@f-eng.tanta.edu.eg},
