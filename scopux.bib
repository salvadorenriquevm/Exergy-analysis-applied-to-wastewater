@ARTICLE{Dağcı2026,
	author = {Dağcı, Oğuzhan and Tozlu, Alperen and Berber, Adnan},
	title = {An exergoeconomic analysis of a wastewater treatment plant: investigation and optimization of sludge drying—a case study},
	year = {2026},
	journal = {International Journal of Energy and Water Resources},
	volume = {10},
	number = {1},
	pages = {},
	doi = {10.1007/s42108-025-00458-5},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105023577539&doi=10.1007%2Fs42108-025-00458-5&partnerID=40&md5=5a5d4435e27df8a663e299b2420d7714},
	affiliations = {Selçuk Üniversitesi, Department of Mechanical Engineering, Selçuklu, Konya, Turkey; Bayburt Üniversitesi, Department of Electricity and Energy, Bayburt, Bayburt, Turkey; Toraighyrov University, Department of Heat Power Engineering, Pavlodar, Pavlodar oblast, Kazakhstan},
	abstract = {The primary parameters in wastewater treatment plant applications are pollutant removal in compliance with standards and energy costs. This study conducts exergy, exergoeconomic, and optimization analyses on the Konya Wastewater Treatment Plant to enhance its energy efficiency. All assessments of the plant were based on actual operational data. Numerical calculations were executed using Engineering Equation Solver software. Exergoeconomic analyses were performed using the Specific Cost Method, while optimization calculations employed the Net Present Value approach. Thermodynamic calculations revealed that the exergy efficiency of the biogas engine was 30.8%, which increased to 39.8% when integrated into a cogeneration system. The overall exergy efficiency of the plant was calculated to be 35.3%, which rose to 58.6% when stabilized sludge was utilized as fuel. During the optimization phase, various drying systems were evaluated, and a hybrid greenhouse-solar-panel drying system was identified as the optimal model. The analyses indicated that the total cost was minimized at the maximum dryness value (70%), suggesting that the greenhouse-type drying system could achieve regional conditions. Compared to thermal and solar energy systems, hybrid systems have been observed to offer significant advantages in first-year costs. Optimization studies reveal that hybrid systems provide 41% greater cost savings in initial investment and operational expenses compared to thermal systems, and 29% greater savings compared to solar energy systems. Meeting the system's energy demand with fossil fuels results in annual emissions of 76,850 tons of CO₂ and 1500 tons of harmful pollutants, equivalent to removing 19,000 cars from traffic or preserving 7300 hectares of forest. Significant soil and ecosystem degradation also occurs. The use of solar energy substantially reduces these environmental impacts, improving air quality and conserving natural resources. © The Author(s), under exclusive licence to Iranian Society of Environmentalists (IRSEN) and Science and Research Branch, Islamic Azad University 2025.},
	author_keywords = {Exergoeconomic analysis; Exergy; Optimization; Sludge drying},
	correspondence_address = {A. Tozlu; Vocational School of Technical Sciences, Electricity and Energy, Bayburt University, Bayburt, 69000, Turkey; email: alperentozlu@bayburt.edu.tr},
	publisher = {Springer},
	issn = {25383604},
	language = {English},
	abbrev_source_title = {Int J Energ Water Res},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Zhu2026,
	author = {Zhu, Liutao and Zhang, Muxing and Wang, Libo and Ma, Yuxin and Zhang, Xiaosong and Huang, Shifang},
	title = {Theoretical minimum specific work for solvent-solute separation in single-solute halide solutions},
	year = {2026},
	journal = {Separation and Purification Technology},
	volume = {380},
	pages = {},
	doi = {10.1016/j.seppur.2025.135299},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105016464045&doi=10.1016%2Fj.seppur.2025.135299&partnerID=40&md5=4c5f2f96648303a4dc1247bf59443c0b},
	affiliations = {Southeast University, School of Energy and Environment, Nanjing, Jiangsu, China; MOE Engineering Research Center of Building Energy Equipment and Environment, Nanjing, China; Nanjing University of Science and Technology, MIIT Key Laboratory of Thermal Control of Electronic Equipment, Nanjing, Jiangsu, China},
	abstract = {Halide salt separation is a fundamental process in desalination, wastewater treatment, and heat pump air-conditioning systems, playing a vital role in water, energy, and environmental sustainability. The theoretical minimum specific separation work (Wₘᵢₙ), which is the minimum work required to extract one unit mass of water, provides a thermodynamic benchmark for water management, energy conservation, and environmentally responsible industrial applications. However, previous calculations of Wₘᵢₙ have largely been based on idealized assumptions. Moreover, the impact of operating parameters on Wₘᵢₙ has received little systematic investigation. This study establishes a rigorous thermodynamic framework that explicitly links Wₘᵢₙ to fundamental operating parameters based on the first and second laws of thermodynamics. The analytical results demonstrate that Wₘᵢₙ is solely governed by three parameters: ambient temperature, feed concentration, and separation ratio. Furthermore, the proposed framework is extended to high-concentration solution systems in the energy sector, enabling systematic evaluation across multiple application scenarios. Through systematic analysis of various type application scenarios, two key findings emerge: (1) The ideal solution approximation shows little deviation for dilute solution but becomes invalid at concentrated solutions, particularly exemplified by sodium chloride solutions where deviations remain below 5 % at mass fractions <8.2 %, and (2) Wₘᵢₙ exhibits exponential dependence on feed concentration and separation ratio, while remaining largely temperature-insensitive. A comparative exergy analysis of industrial-scale processes identifies technology-specific optimization pathways. Reverse osmosis (RO) achieves 41.60 % second-law efficiency for brackish water desalination (mass fraction <10 %), owing to the low osmotic pressure and near-ideal solution behavior. Mechanical vapor recompression (MVR) demonstrates superior efficiency (49.64 %) for concentrated solution (mass fraction >10 %) due to highly effective recovery of the latent heat of water vapor. This work offers a benchmark for evaluating energy efficiency and guidance on parameter optimization for future research and innovation in energy-efficient separation technologies, thereby supporting the design of more sustainable industrial processes and contributing to long-term sustainability. © 2025},
	author_keywords = {Desalination; Halide solutions; Minimum separation work; Solvent-solute separation; Thermodynamic analysis},
	keywords = {Air conditioning; Benchmarking; Energy efficiency; Engineering research; Industrial research; Osmosis; Sodium chloride; Sustainable development; Temperature; Wastewater treatment; Water conservation; Energy; Feed concentration ratio; Halide solutions; Mass-fraction; Minimum separation work; Operating parameters; Separation work; Solvent-solute separation; Theoretical minimum; Thermo dynamic analysis; Thermoanalysis},
	correspondence_address = {M. Zhang; MIIT Key Laboratory of Thermal Control of Electronic Equipment, School of Energy and Power Engineering, Nanjing University of Science and Technology, Nanjing, 210094, China; email: muxing@njust.edu.cn; S. Huang; School of Energy and Environment, Southeast University, Nanjing, 210096, China; email: shifang_huang@seu.edu.cn},
	publisher = {Elsevier B.V.},
	issn = {13835866},
	coden = {SPUTF},
	language = {English},
	abbrev_source_title = {Sep. Purif. Technol.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

