	pages = {},
	doi = {10.1080/15567036.2025.2525377},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105009844089&doi=10.1080%2F15567036.2025.2525377&partnerID=40&md5=d6c2a2ffcdee1801ba2fb4b8c54b082c},
	affiliations = {SSM Institute of Engineering and Technology, Department of Mechanical Engineering, Dindigul, TN, India; SNS College of Technology, Department of Mechanical Engineering, Coimbatore, TN, India; SSM Institute of Engineering and Technology, Department of Chemistry, Dindigul, TN, India; Coimbatore Institute of Engineering and Technology, Department of Mechanical Engineering, Coimbatore, TN, India},
	abstract = {This study presents a novel approach to wastewater treatment by integrating solar still desalination with multilayer filtration, offering a sustainable alternative to energy-intensive conventional methods. The research evaluated the energy, exergy and efficiency of four different wastewater samples: kitchen wastewater (KW), borewell water (BW), reverse osmosis wastewater (ROW), and sewage wastewater (SW), testing each at various water depths. The experimental results were compared against BW as a control and validated with a numerical model. Water quality analysis, conducted according to IS 10,500:2012 standards, revealed significant improvements in the physicochemical and bacteriological properties of all treated samples. The SW solar still demonstrated superior performance with the highest exergy output and efficiency among all samples. Optimal yield was achieved at a water depth of 1 cm, with the BW reference still producing 1,872 mL/day, while SW, KW, and ROW stills yielded 1,603, 1,661, and 1,783 mL/day, respectively. All treated samples met water quality standards, demonstrating that this integrated method is a practical and sustainable solution, particularly where traditional treatments are not feasible. © 2025 Taylor & Francis Group, LLC.},
	author_keywords = {Multilayer filtration; numerical analysis; solar still; wastewater sources; yield},
	keywords = {Desalination; Exergy; Multilayers; Physicochemical properties; Quality control; Reclamation; Sewage; Solar heating; Wastewater treatment; Water filtration; Water quality; Comparative analyzes; Energy; Experimental approaches; Kitchen wastewaters; Multilayer filtration; Solar desalination; Solar stills; Wastewater sources; Water depth; Yield; Numerical analysis},
