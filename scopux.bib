@ARTICLE{Li201973,
	author = {Li, Kaikun and Wang, Qinhui and Fang, Mengxiang and Shaikh, Abdul Rahim and Xie, Guilin and Luo, Zhongyang},
	title = {Techno-Economic Analysis of a Coal Staged Conversion Polygeneration System for Power and Chemicals Production},
