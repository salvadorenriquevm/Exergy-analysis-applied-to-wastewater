@ARTICLE{Tzanakakis20113082,
	author = {Tzanakakis, Vasileios A. and Angelakis, Andreas Nikolaos},
	title = {Chemical exergy as a unified and objective indicator in the assessment and optimization of land treatment systems},
	year = {2011},
	journal = {Ecological Modelling},
	volume = {222},
