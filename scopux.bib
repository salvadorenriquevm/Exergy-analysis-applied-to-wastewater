@ARTICLE{Egiza2024,
	author = {Egiza, Mohamed and Diab, Mohamed Ragab and Faisal, Nadimul Haque and Elsheikh, Ammar H.},
	title = {Natural fibers for enhanced efficiency and sustainability in solar desalination: A review},
	year = {2024},
	journal = {Solar Energy},
