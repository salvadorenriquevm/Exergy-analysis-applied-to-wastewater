	affiliations = {National Key Laboratory of Efficient and Clean Energy Utilization, Hangzhou, Zhejiang, China},
	abstract = {Steady-state process simulation and techno-economic analysis of a pyrolysis-based coal staged conversion polygeneration (CSCP) plant, integrated with wastewater biochemical treatment after phenol-ammonia recovery, are studied using Aspen Plus software. Appropriate models for the proposed system are set up in detail. Furthermore, by optimization of a methanation unit, a conventional supercritical circulating fluidized bed (SCCFB) power plant with the same capacity is chosen for comparison. Simulation results reveal that system energy and exergy efficiency of the CSCP system can reach much higher values than those of a conventional SCCFB power plant. In conclusion, a CSCP plant will have practical and economic advantages in the near future. © 2019 WILEY-VCH Verlag GmbH & Co. KGaA, Weinheim},
	author_keywords = {Coal pyrolysis; Coal staged conversion utilization; Phenol-ammonia recovery; Synthetic natural gas; Techno-economic analysis},
