	abbrev_source_title = {ASME Int. Conf. Fuel Cell Sci., Eng. Technol. Collocated ASME Int. Conf. Energy Sustainability, FUELCELL},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
