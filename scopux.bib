	author = {Shen, Jiubing and Tan, Niugao and Jiang, Lele and Wei, Wenbing and Chen, Yang and Cao, Junjie},
	title = {Study on multi-effect mechanical vapor recompression systems used for the concentration of industrial high salt wastewater},
	year = {2023},
