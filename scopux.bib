	year = {2026},
	journal = {Process Safety and Environmental Protection},
	volume = {206},
	pages = {},
	doi = {10.1016/j.psep.2025.108336},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105025466248&doi=10.1016%2Fj.psep.2025.108336&partnerID=40&md5=357797c207d75e58440f30642ff5fbb5},
	affiliations = {Faculty of Engineering, Kafr el-sheikh, Kafr el-Sheikh, Egypt; Faculty of Engineering, Department of Mechanical Engineering, Kafr el-sheikh, Kafr el-Sheikh, Egypt},
	abstract = {Freshwater scarcity is an urgent global issue that threatens sustainable development and energy conservation. This study tackles this challenge by enhancing hemispherical solar still (HSS) performance using cost-effective, sustainable porous adsorbents derived from agricultural waste. The hemispherical geometry was specifically chosen for its ability to maximize uniform solar irradiation and condensation area, resulting in improved freshwater productivity and system efficiency. Three activated carbon materials, coconut shell (CNS), hydrochloric acid-treated fruit tree charcoal (CHL), and carbonized corncobs (CCC); were integrated into HSS basins. Experiments conducted with brackish water (TDS: 1864 mg/L) and treated wastewater (TDS: 507 mg/L) revealed notable improvements: daily freshwater productivity increased by 33.00 %, 37.88 %, and 41.02 % for CNS, CHL, and CCC (using treated wastewater), respectively, compared to a standard HSS. The lowest water production cost was achieved with CCC, at 0.0130 USD/L, representing a 28.57 % reduction. Treated wastewater consistently yielded superior thermal and exergy efficiencies and improved water quality indices. Notably, the use of agricultural waste adsorbents enabled water quality upgrades from “very poor” or “unfit” to “good” or “excellent,” in line with WHO and Egyptian standards. These results demonstrate the practical contribution of integrating modified carbonized agricultural waste into optimized HSS design, and the significant implications for energy-efficient, affordable, and scalable desalination solutions. © 2025 The Institution of Chemical Engineers},
	author_keywords = {Agricultural waste; Desalination; Energy efficiency; Freshwater quality; Hemispherical solar still; Output},
	keywords = {Adsorbents; Cost effectiveness; Forestry; Sustainable development; Wastewater treatment; Water filtration; Agricultural waste materials; Coconut shells; Energy; Fresh Water; Freshwater quality; Freshwater scarcity; Global issues; Hemispherical solar stills; Output; Treated wastewater; Agricultural wastes; Desalination; Energy efficiency},
	correspondence_address = {A. Khalil; Civil Engineering Department, Faculty of Engineering, Kafrelsheikh University, Kafrelsheikh, 33516, Egypt; email: Ahmed.khalil@eng.kfs.edu.eg},
