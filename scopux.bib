	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85211036928&doi=10.1016%2Fj.jece.2024.114991&partnerID=40&md5=6f7cd86c9fe5f635cdbb26a12b7e9de0},
	affiliations = {Shanghai Jiao Tong University, School of Environmental Science and Engineering, Shanghai, China; Ltd., Jinan, Shandong, China; Shanghai Jiao Tong University, Shanghai, China},
	abstract = {Dielectric barrier discharge (DBD) and proton exchange membrane (PEM) electrolysis are widely recognized techniques for ozone disinfection. DBD, when using air, emits nitrogen oxides, posing environmental concerns, while an oxygen source elevates costs. Although PEM electrolysis can produce hydrogen and higher ozone concentrations, it demands greater energy and operational expenses. However, comparative assessments of their exergy efficiency and economic viability have been lacking. This study contrasted two ozone disinfection designs for secondary effluent from wastewater treatment plants using exergy and exergoeconomic analyses. The findings revealed that PEM electrolysis showed a higher total exergy efficiency (44.77 %) when including hydrogen production, compared to DBD's 33.16 %. However, PEM also exhibited higher exergy destruction (746.6 kW) versus DBD (317.0 kW), mainly attributed to the ozone generator. Exergoeconomic analysis indicated that the unit product exergy cost of treated water for DBD was 2.62 times higher than for PEM. Considering the economic benefits of hydrogen production, PEM's net cost is 83.39 USD/h, slightly higher than DBD's 63.34 USD/h. Notably, the relative cost differences of ozone generators and exhaust gas treatment highlight the potential for optimizing economic benefits. Sensitivity analysis underscored the impact of interest rates and electricity prices. Overall, PEM electrolysis presents a promising alternative for ozone disinfection in wastewater treatment plants, offering higher exergy efficiency and potential economic benefits, especially with hydrogen production. The higher exergy destruction in PEM suggests room for further optimization, particularly in the ozone generator. © 2024 Elsevier Ltd},
	author_keywords = {Dielectric barrier discharge; Exergoeconomics; Exergy; Ozone disinfection; Proton exchange membrane electrolysis; Secondary effluent},
	keywords = {Dielectric barrier discharge; Dielectric devices; Disinfection; Effluent treatment; Exhaust gases; Ozone water treatment; Wastewater treatment; Dielectric barrier discharges; Exergoeconomics; Exergy efficiencies; Membrane electrolysis; Ozone disinfection; Ozone generator; Proton exchange membrane electrolyse; Proton exchange membranes; Secondary effluent; Waste water treatment plants; Effluents},
