@ARTICLE{Shabgard20191,
	author = {Shabgard, Hamidreza and Parthasarathy, Ramkumar N. and Xu, Ben},
	title = {Energy and exergy analysis of a novel multiple-effect vapor chamber distillation system for high-salinity wastewater treatment},
	year = {2019},
	journal = {Desalination and Water Treatment},
	volume = {171},
	pages = {1 - 17},
	doi = {10.5004/dwt.2019.25017},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85076628271&doi=10.5004%2Fdwt.2019.25017&partnerID=40&md5=ee34640700f6e15ed251aed6ed15753d},
	affiliations = {Gallogly College of Engineering, Norman, OK, United States; The University of Texas Rio Grande Valley, Department of Mechanical Engineering, Brownsville, TX, United States},
	abstract = {A novel modular thermally-driven multiple-effect vapor chamber distillation (MVCD) system is presented for compact and portable desalination applications. The MVCD system consists of several vapor chambers connected in series with the condenser section of the upstream vapor chambers serving as the evaporator section of the following effect. A heat transfer model accounting for the major thermal resistances was developed to predict the heat transfer and distilled water production rates. A mass transfer analysis was performed to evaluate the effect of the accumulation of the non-condens-able gasses within the chambers. An exergy analysis was also conducted to quantify the efficiency of the system from the viewpoint of the second law of thermodynamics. It was found that for a fixed number of effects, increasing the hot-end temperature increased the distillation rate and decreased the second law efficiency. On the other hand, increasing the number of effects at a fixed hot-end temperature resulted in increased distillation rate and second law efficiency. The increased salinity of the feed water resulted in smaller distillation rates and greater second law efficiency. For all the cases, it was found that sensible heat recovery from the discharging fluids could improve the gained output ratio (GOR) and the second law efficiency by about 10%. Quantitatively, at a hot-end temperature of 70°C, feed water salinity of 35 ppt and recovery ratio of 36%, the MVCD system with six effects and energy recovery from the discharging fluids yielded a GOR of 5.0 and a second law efficiency of 3.8%. © 2019 The Author(s).},
	author_keywords = {Exergy analysis; Multiple-effect vapor chamber; Thermal desalination},
	keywords = {desalination; distillation; exergy; heat transfer; salinity; thermodynamics; wastewater treatment},
	correspondence_address = {H. Shabgard; School of Aerospace and Mechanical Engineering, University of Oklahoma, Norman, 865 Asp Ave., 73019, United States; email: shabgard@ou.edu},
