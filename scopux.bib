	keywords = {Carbon capture; Carbon capture and storage; Environmental impact; Exergy; Flow of gases; Gasification; Life cycle; Life cycle assessment; Thermoanalysis; Auto-thermal; Energy; Exergy loss; Gasification temperatures; Heat coupling; Oily wastewater; Self-heat; Supercritical water; Supercritical water gasification; Thermo dynamic analysis; Hydrogen production; carbon sequestration; combustion; energy efficiency; environmental effect; gas flow; wastewater treatment},
